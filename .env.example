APP_NAME="Businzo RCMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

RAZORPAY_KEY=your_razorpay_key_here
RAZORPAY_SECRET=your_razorpay_secret_here
RWA_REGISTRATION_FEE=2499

# Production: set APP_ENV=production, APP_DEBUG=false, APP_URL=https://yourdomain.com
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=strict

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hms
DB_USERNAME=root
DB_PASSWORD=change-me-strong-password

SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=file

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=change-me-strong-redis-password
REDIS_PORT=6379

QUEUE_CONNECTION=redis

FILESYSTEM_DISK=local

# Firebase Cloud Messaging (FCM) — credentials stored in `firebase_credentials` table
# One-time import: php artisan firebase:import-credentials storage/app/firebase-credentials.json
FIREBASE_PROJECT=app

# Push notifications (laravel-notification-channels/fcm)
PUSH_NOTIFICATIONS_ENABLED=true
PUSH_TOPIC_PREFIX=org
